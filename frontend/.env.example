# ========================================
# 🎨 夢ログ フロントエンド環境変数テンプレート  
# ========================================
# 
# このファイルをコピーして frontend/.env.local を作成してください
# cp frontend/.env.example frontend/.env.local
# 
# ⚠️ 重要: NEXT_PUBLIC_ プレフィックスは公開されるため機密情報は含めない

# ========================================
# 🌐 API接続設定
# ========================================
# バックエンドAPIのURL（ブラウザからアクセス可能なURL）
NEXT_PUBLIC_API_URL=http://localhost:3001

# サーバーサイドからの内部API接続用URL（Docker環境では service名:port）
INTERNAL_API_URL=http://backend:3001

# --- Vercelデプロイ時のAPIルーティング（重要・lib/api-config.ts が参照）---
# ブラウザ側のAPI baseは NEXT_PUBLIC_VERCEL_ENV で決まる:
#   production → "/proxy"（next.config.mjs の rewrite で Render の Rails へ同一オリジン転送。
#                          Cookie認証を Vercel ドメインで成立させるための設計）
#   preview    → ""（相対パス＝認証は意図的に無効。Previewが本番データに触れないようにするため。
#                    ※Preview URLでは /auth/login が Next.js に当たり 404 になるのは仕様）
#   それ以外    → NEXT_PUBLIC_API_URL（未設定なら http://localhost:3001）
#
# ⚠️ 本番(Vercel Production)では **Vercel の Environment Variables に
#    NEXT_PUBLIC_VERCEL_ENV=production を必ず設定**すること（NEXT_PUBLIC_* はビルド時に埋め込まれる）。
#    未設定/不一致だと本番ブラウザが /proxy に切り替わらず、ログイン等の /auth/* が 404 になる。
# ローカル(.env.local)では通常このプレフィックスは不要（NEXT_PUBLIC_API_URL が使われる）。
# NEXT_PUBLIC_VERCEL_ENV=production


# ========================================
# 🔍 Sentry エラー監視
# ========================================
# Sentry プロジェクトの DSN (Data Source Name)
# Sentry ダッシュボード → Settings → Projects → Client Keys で確認できます
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
# ========================================
# 🛠️ 開発環境設定
# ========================================
# Next.js環境（development | production | test）
NODE_ENV=development

# ファイル変更監視設定（Mac/Windowsで必要な場合）
WATCHPACK_POLLING=true
CHOKIDAR_USEPOLLING=true

# ========================================
# 📝 環境変数設定手順
# ========================================
# 
# 1. このファイルをコピー:
#    cp frontend/.env.example frontend/.env.local
# 
# 2. 必要に応じて値を調整:
#    - NEXT_PUBLIC_API_URL: バックエンドのURL
#    - INTERNAL_API_URL: Docker内部通信用URL
# 
# 3. ファイル権限を制限:
#    chmod 600 frontend/.env.local